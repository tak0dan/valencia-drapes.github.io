{
  "themeSelection": {
    "strategy": "lastTrueWins",
    "styles": [
      {
        "id": "products-local",
        "enabled": true,
        "css": "linked-css/products/products-local.css"
      },
      {
        "id": "products-github",
        "enabled": false,
        "css": "linked-css/products/products-github.css"
      }
    ]
  },
  "viewportSwitches": [
    {
      "name": "desktop",
      "when": {
        "minWidth": 1024
      }
    },
    {
      "name": "tablet",
      "when": {
        "minWidth": 768,
        "maxWidth": 1023
      }
    },
    {
      "name": "mobile",
      "when": {
        "maxWidth": 767
      }
    }
  ],
  "sections": [
    {
      "id": "catalogo",
      "base": {
        "measures": {
          "top": "0px",
          "bottom": "40px"
        },
        "overrides": {
          "titleScale": 1,
          "tileOverlayPercent": 60,
          "titleOutlineWidth": 1,
          "titleOutlineOpacity": 1.3,
          "descriptionColor": "rgba(235, 235, 235, 0.92)",
          "idleBorderColor": "rgba(0, 0, 0, 0.45)",
          "hoverBorderColor": "var(--tile-border-color)"
        }
      },
      "switchCases": {
        "desktop": {
          "measures": {
            "bottom": "40px"
          },
          "overrides": {
            "titleScale": 1
          }
        },
        "tablet": {
          "measures": {
            "bottom": "30px"
          },
          "overrides": {
            "titleScale": 0.86
          }
        },
        "mobile": {
          "measures": {
            "bottom": "22px"
          },
          "overrides": {
            "titleScale": 0.72,
            "descriptionColor": "rgba(230, 230, 230, 0.9)"
          }
        }
      }
    }
  ]
}
